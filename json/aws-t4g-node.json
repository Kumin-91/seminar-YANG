{
  "hybrid-cloud:cluster": {
    "node": [
      {
        "name": "aws-t4g-node",
        "compute": {
          "arch": "arm64",
          "vcpu": 2,
          "memory": 4,
          "burstable": true
        },
        "network": {
          "tailscale-ip": "100.100.2.101",
          "zone": "cloud"
        },
        "storage": {
          "type": "mount-only",
          "cache-size": 5
        },
        "role-assignment": [
          {
            "role": "server",
            "priority": "primary"
          },
          {
            "role": "agent",
            "priority": "fallback"
          }
        ]
      }
    ]
  }
}
