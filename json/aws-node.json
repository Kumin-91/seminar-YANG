{
  "hybrid-cloud:cluster": {
    "node": [
      {
        "name": "AWS-Control-Node",
        "role-assignment": [
          {
            "role": "server",
            "priority": "primary"
          },
          {
            "role": "agent",
            "priority": "fallback"
          }
        ],
        "compute": {
          "vcpu": 2,
          "memory": 4,
          "burstable": true
        },
        "network": {
          "tailscale-ip": "100.100.1.201",
          "zone": "cloud"
        },
        "storage": {
          "type": "mount-only",
          "cache-size": 5
        }
      }
    ]
  }
}
