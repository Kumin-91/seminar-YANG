{
  "hybrid-cloud:cluster": {
    "node": [
      {
        "name": "Site-A-Storage-Node",
        "role-assignment": [
          {
            "role": "server",
            "priority": "secondary"
          },
          {
            "role": "agent",
            "priority": "primary"
          }
        ],
        "compute": {
          "vcpu": 4,
          "memory": 8,
          "burstable": true
        },
        "network": {
          "tailscale-ip": "100.100.1.254",
          "zone": "on-prem"
        },
        "storage": {
          "type": "s3-backed",
          "cache-size": 100
        }
      }
    ]
  }
}
