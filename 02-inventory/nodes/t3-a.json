{
  "hybrid-cloud:cluster": {
    "node": [
      {
        "name": "t3-a",
        "k8s-role-assignment": {
            "node-role": "control-plane",
            "bootstrap-role": "join"
          },
        "compute": {
          "platform": "aws",
          "arch": "x86_64",
          "instance-type": "t3.medium",
          "ebs-size": 20
        },
        "network": {
          "ssh-user": "ec2-user",
          "ssh-port": 22,
          "public-ip-required": true,
          "use-eip": false
        },
        "storage": {
          "s3-endpoint": "s3.aoimiu.com",
          "redis-endpoint": "100.100.1.254:4279",
          "cache-size": 5
        }
      }
    ]
  }
}