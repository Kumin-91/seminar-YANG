{
  "hybrid-cloud:cluster": {
    "node": [
      {
        "name": "aws-t4g-node",
        "role-assignment": [
          {
            "role": "server",
            "priority": "primary"
          },
          {
            "role": "agent",
            "priority": "fallback"
          }
        ],
        "compute": {
          "platform": "aws",
          "arch": "arm64",
          "instance-type": "t4g.medium",
          "ebs-size": 20
        },
        "network": {
          "ssh-user": "ec2-user",
          "ssh-port": 22,
          "public-ip-required": true,
          "use-eip": false
        },
        "storage": {
          "s3-endpoint": "s3.example.com",
          "redis-endpoint": "100.100.1.254:4279",
          "secret-file-path": "storage-client.env",
          "cache-size": 5
        }
      }
    ]
  }
}